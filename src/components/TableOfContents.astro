---
// src/components/TableOfContents.astro
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;

interface TocNode {
  heading: MarkdownHeading;
  children: TocNode[];
}

const toc = headings.filter(h => h.depth >= 1 && h.depth <= 4);

const roots: TocNode[] = [];
const stack: TocNode[] = [];

for (const heading of toc) {
  const node: TocNode = { heading, children: [] };

  while (stack.length > 0 && stack[stack.length - 1].heading.depth >= heading.depth) {
    stack.pop();
  }

  const parent = stack[stack.length - 1];
  if (parent) {
    parent.children.push(node);
  } else {
    roots.push(node);
  }

  stack.push(node);
}
---

<nav class="toc-container">
  <h3 class="toc-title">ON THIS PAGE</h3>
  <ul class="toc-list">
    {roots.map(node => (
      <li class={`toc-node depth-${node.heading.depth}`} data-toc-node={node.heading.slug}>
        <a class="toc-link" href={`#${node.heading.slug}`}>
          {node.heading.text}
        </a>

        {node.children.length > 0 && (
          <ul class="toc-sublist">
            {node.children.map(child => (
              <li
                class={`toc-node depth-${child.heading.depth}`}
                data-toc-node={child.heading.slug}
                data-parent-slug={node.heading.slug}
              >
                <a class="toc-link" href={`#${child.heading.slug}`}>
                  {child.heading.text}
                </a>

                {child.children.length > 0 && (
                  <ul class="toc-sublist">
                    {child.children.map(grandchild => (
                      <li
                        class={`toc-node depth-${grandchild.heading.depth}`}
                        data-toc-node={grandchild.heading.slug}
                        data-parent-slug={child.heading.slug}
                      >
                        <a class="toc-link" href={`#${grandchild.heading.slug}`}>
                          {grandchild.heading.text}
                        </a>

                        {grandchild.children.length > 0 && (
                          <ul class="toc-sublist">
                            {grandchild.children.map(greatGrandchild => (
                              <li
                                class={`toc-node depth-${greatGrandchild.heading.depth}`}
                                data-toc-node={greatGrandchild.heading.slug}
                                data-parent-slug={grandchild.heading.slug}
                              >
                                <a class="toc-link" href={`#${greatGrandchild.heading.slug}`}>
                                  {greatGrandchild.heading.text}
                                </a>
                              </li>
                            ))}
                          </ul>
                        )}
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        )}
      </li>
    ))}
  </ul>
</nav>

<script>
  const tocNodes = Array.from(document.querySelectorAll<HTMLElement>('[data-toc-node]'));
  const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.toc-link'));
  const articleHeadings = Array.from(
    document.querySelectorAll<HTMLElement>('.markdown-body h1[id], .markdown-body h2[id], .markdown-body h3[id], .markdown-body h4[id]')
  );

  const nodeBySlug = new Map(
    tocNodes.map(node => [node.dataset.tocNode as string, node])
  );

  const getAncestorSlugs = (slug: string) => {
    const slugs = new Set([slug]);
    let current = nodeBySlug.get(slug);

    while (current?.dataset.parentSlug) {
      const parentSlug = current.dataset.parentSlug;
      slugs.add(parentSlug);
      current = nodeBySlug.get(parentSlug);
    }

    return slugs;
  };

  const getDescendantSlugs = (slug: string) => {
    const slugs = new Set<string>();
    const current = nodeBySlug.get(slug);

    current?.querySelectorAll<HTMLElement>('[data-toc-node]').forEach(node => {
      if (node.dataset.tocNode) slugs.add(node.dataset.tocNode);
    });

    return slugs;
  };

  const setActiveHeading = (slug: string) => {
    const activeBranchSlugs = getAncestorSlugs(slug);
    const expandedSlugs = new Set([
      ...activeBranchSlugs,
      ...getDescendantSlugs(slug),
    ]);

    tocNodes.forEach(node => {
      const nodeSlug = node.dataset.tocNode;
      node.classList.toggle('is-expanded', Boolean(nodeSlug && expandedSlugs.has(nodeSlug)));
      node.classList.toggle('is-active-branch', Boolean(nodeSlug && activeBranchSlugs.has(nodeSlug)));
    });

    tocLinks.forEach(link => {
      const linkSlug = decodeURIComponent(link.hash.slice(1));
      link.classList.toggle('is-active', linkSlug === slug);
    });
  };

  const getActiveHeadingSlug = () => {
    const scrollOffset = 120;
    let activeHeading = articleHeadings[0];

    for (const heading of articleHeadings) {
      if (heading.getBoundingClientRect().top <= scrollOffset) {
        activeHeading = heading;
      } else {
        break;
      }
    }

    return activeHeading?.id;
  };

  const updateActiveHeading = () => {
    const slug = getActiveHeadingSlug();
    if (slug) setActiveHeading(slug);
  };

  tocLinks.forEach(link => {
    link.addEventListener('click', () => {
      const slug = decodeURIComponent(link.hash.slice(1));
      if (slug) setActiveHeading(slug);
    });
  });

  updateActiveHeading();
  window.addEventListener('scroll', updateActiveHeading, { passive: true });
  window.addEventListener('resize', updateActiveHeading);
</script>

<style>
  .toc-container {
    position: sticky;
    top: 2rem;
    padding-left: 1rem;
    border-left: 1px solid rgba(0,0,0,0.05);
  }

  .toc-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 1px;
    color: #aaa;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-node {
    margin-bottom: 0.35rem;
  }

  .toc-link {
    font-size: 0.85rem;
    color: var(--text-sub);
    text-decoration: none;
    transition: color 0.2s;
    display: block;
    line-height: 1.4;
    padding: 0.25rem 0;
  }

  .toc-link:hover,
  .toc-link.is-active,
  .toc-node.is-active-branch > .toc-link {
    color: var(--accent-library);
  }

  .depth-1 > .toc-link,
  .depth-2 > .toc-link {
    font-weight: 600;
  }

  .depth-3 > .toc-link {
    font-size: 0.8rem;
  }

  .depth-4 > .toc-link {
    font-size: 0.78rem;
    color: #999;
  }

  .toc-sublist {
    list-style: none;
    margin: 0.2rem 0 0.45rem;
    padding: 0 0 0 1rem;
    border-left: 1px solid rgba(0,0,0,0.06);
    display: none;
  }

  .toc-node.is-expanded > .toc-sublist {
    display: block;
  }
</style>
